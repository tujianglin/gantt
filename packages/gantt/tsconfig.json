{
  "compilerOptions": {
    "target": "ES2018",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2018"],
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": []
  },
  "include": ["src/**/*.ts", "vite.config.ts", "types/**/*.d.ts"]
}
