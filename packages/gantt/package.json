{
  "name": "@wimi/gantt",
  "version": "0.1.6",
  "description": "Framework-agnostic SVG scheduling gantt chart.",
  "type": "module",
  "main": "dist/VanillaGantt.cjs",
  "module": "dist/VanillaGantt.es.js",
  "unpkg": "dist/VanillaGantt.umd.js",
  "style": "dist/VanillaGantt.css",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/VanillaGantt.es.js",
      "require": "./dist/VanillaGantt.cjs"
    },
    "./style.css": "./dist/VanillaGantt.css"
  },
  "files": [
    "dist",
    "src",
    "types",
    "README.md"
  ],
  "scripts": {
    "build": "vite build"
  },
  "sideEffects": [
    "*.css",
    "src/*.css"
  ],
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
